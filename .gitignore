# ════════════════════════════════════════════════════
# .gitignore — files that must NEVER go to GitHub
# ════════════════════════════════════════════════════

# OS clutter
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# Editor folders
.vscode/
.idea/
*.swp
*.swo
*~

# Secrets (if you ever add a backend)
.env
.env.local
.env.production
*.pem
*.key
secrets.js
secrets.json

# Node (if you ever add build tools)
node_modules/
npm-debug.log*
yarn-error.log*
dist/
build/

# Keep this file itself tracked
!.gitignore

# Local setup notes (contains default credentials)
SETUP.md
